import requests

def research_tech_book(query):
    """
    Searches for technical books based on a keyword/title.
    """
    # Google Books API endpoint
    base_url = "https://www.googleapis.com/books/v1/volumes"
    
    # Parameters for the search
    params = {
        'q': query,
        'maxResults': 5,
        'printType': 'books'
    }

    try:
        response = requests.get(base_url, params=params)
        response.raise_for_status() # Check for HTTP errors
        data = response.json()

        if "items" not in data:
            return "No books found for that topic."

        books = []
        for item in data["items"]:
            info = item.get("volumeInfo", {})
            book_details = {
                "Title": info.get("title", "N/A"),
                "Authors": ", ".join(info.get("authors", ["Unknown Author"])),
                "Published": info.get("publishedDate", "N/A"),
                "Description": info.get("description", "No description available.")[:200] + "...",
                "Link": info.get("infoLink", "N/A")
            }
            books.append(book_details)
        
        return books

    except requests.exceptions.RequestException as e:
        return f"An error occurred: {e}"

# --- Execution ---
topic = "Deep Learning with Python"
results = research_tech_book(topic)

if isinstance(results, list):
    print(f"--- Top Research Results for: {topic} ---\n")
    for i, book in enumerate(results, 1):
        print(f"{i}. {book['Title']}")
        print(f"   Author(s): {book['Authors']}")
        print(f"   Link: {book['Link']}\n")
else:
    print(results)
